  'glen waverley':{name:'Glen Waverley',medH:1420000,medU:680000, yH:2.9,yU:4.1, g5:30,g10:62, vac:1.4,dom:16, dist:20, train:8,school:10,crime:2,cafe:7,dev:6,live:9},
  boxhill:       {name:'Box Hill',      medH:1250000,medU:590000, yH:3.1,yU:4.6, g5:35,g10:74, vac:1.8,dom:19, dist:15, train:8,school:8,crime:4,cafe:8,dev:8,live:8},
  doncaster:     {name:'Doncaster',     medH:1350000,medU:640000, yH:2.9,yU:4.2, g5:28,g10:60, vac:1.6,dom:18, dist:16, train:4,school:8,crime:3,cafe:6,dev:5,live:8},
  ringwood:      {name:'Ringwood',      medH:980000, medU:530000, yH:3.5,yU:4.8, g5:33,g10:70, vac:1.9,dom:20, dist:25, train:8,school:7,crime:5,cafe:6,dev:7,live:7},
