  pakenham:      {name:'Pakenham',      medH:580000, medU:350000, yH:5.0,yU:6.5, g5:44,g10:90, vac:1.8,dom:20, dist:55, train:7,school:6,crime:5,cafe:4,dev:8,live:6},
  werribee:      {name:'Werribee',      medH:540000, medU:330000, yH:5.2,yU:6.8, g5:46,g10:95, vac:2.2,dom:24, dist:32, train:7,school:5,crime:6,cafe:4,dev:8,live:5},
  sunbury:       {name:'Sunbury',       medH:620000, medU:380000, yH:4.6,yU:6.0, g5:40,g10:82, vac:1.9,dom:21, dist:40, train:7,school:6,crime:4,cafe:5,dev:7,live:6},
};

function getMedian(d, type) {
  if(type==='house') return d.medH;
  if(type==='unit') return d.medU;
  return Math.round((d.medH + d.medU) / 2);
}
function getYield(d, type) {
  if(type==='house') return d.yH;
  if(type==='unit') return d.yU;
  return ((d.yH + d.yU) / 2);
}
function fmt(n){return '$'+Math.round(n).toLocaleString('en-AU')}
function fmtPct(n){return n.toFixed(1)+'%'}
function openTab(name,btn){
  document.querySelectorAll('.tab-link').forEach(b=>b.classList.remove('active'));
  document.querySelectorAll('.tab-panel').forEach(p=>p.classList.remove('active'));
  document.getElementById('tab-'+name).classList.add('active');
  btn.classList.add('active');
}

function score(d, type) {
  const y = getYield(d, type);
  const med = getMedian(d, type);
  return {
    affordability: Math.max(0, Math.min(10, 10 - (med / 200000))),
    yield:         Math.min(10, y * 1.6),
    growth:        Math.min(10, d.g10 / 10),
    liveability:   d.live,
    transport:     d.train,
    schools:       d.school,
    safety:        10 - d.crime,
    development:   d.dev,
  };
}

function totalScore(sc) {
  return ((sc.yield * 2 + sc.growth * 2 + sc.affordability * 1.5 + sc.liveability + sc.transport + sc.schools + sc.safety + sc.development * 0.5) / 11.5).toFixed(1);
}

function compare() {
  const keyA = document.getElementById('suburbA').value;
  const keyB = document.getElementById('suburbB').value;
  const typeA = document.getElementById('typeA').value;
  const typeB = document.getElementById('typeB').value;
  const dA = SUBURBS[keyA], dB = SUBURBS[keyB];
  const scA = score(dA, typeA), scB = score(dB, typeB);
  const totA = parseFloat(totalScore(scA)), totB = parseFloat(totalScore(scB));
  const medA = getMedian(dA, typeA), medB = getMedian(dB, typeB);
  const yA = getYield(dA, typeA), yB = getYield(dB, typeB);

  // ── HEADERS ──
  document.getElementById('compareHeader').innerHTML = `
    <div class="suburb-header a">
      <div class="sh-tag">Suburb A</div>
      <div class="sh-name">${dA.name}</div>
      <div class="sh-type">${typeA === 'house' ? 'Houses' : typeA === 'unit' ? 'Units / Apartments' : 'Mixed'} · ${dA.dist}km from CBD</div>
      <div style="margin-top:12px;display:flex;align-items:baseline;gap:12px">
        <div><div class="sh-score">${totA}</div><div class="sh-score-label">Investment Score</div></div>
      </div>
    </div>
    <div class="suburb-header b">
      <div class="sh-tag">Suburb B</div>
      <div class="sh-name">${dB.name}</div>
      <div class="sh-type">${typeB === 'house' ? 'Houses' : typeB === 'unit' ? 'Units / Apartments' : 'Mixed'} · ${dB.dist}km from CBD</div>
      <div style="margin-top:12px;display:flex;align-items:baseline;gap:12px">
        <div><div class="sh-score">${totB}</div><div class="sh-score-label">Investment Score</div></div>
      </div>
    </div>`;

  // ── RECOMMENDATION ──
  let winner, winnerSide, recBody, pills;
  const diff = Math.abs(totA - totB);
  if (diff < 0.4) {
    winner = 'Comparable suburbs — depends on your strategy';
    winnerSide = 'tie';
    recBody = `${dA.name} and ${dB.name} score within ${diff.toFixed(1)} points of each other, which means neither has a clear overall edge. The right choice depends entirely on what you prioritise: ${dA.name} offers ${yA > yB ? 'stronger rental yield' : 'better capital growth potential'}, while ${dB.name} suits ${medB < medA ? 'buyers with a tighter budget' : 'those seeking a premium location'}.`;
    pills = [`<span class="rec-pill neutral">Close call</span>`,`<span class="rec-pill neutral">Strategy-dependent</span>`];
  } else if (totA > totB) {
    winner = `${dA.name} edges ahead`;
    winnerSide = 'a';
    recBody = `${dA.name} scores ${totA} vs ${dB.name}'s ${totB} — a ${diff.toFixed(1)}-point lead. The key advantages are ${scA.yield > scB.yield ? 'stronger rental yield' : ''}${scA.growth > scB.growth ? (scA.yield > scB.yield ? ' and ' : '') + 'higher historical capital growth' : ''}${scA.affordability > scB.affordability ? ' and lower entry cost' : ''}. That said, ${dB.name} may suit buyers who specifically want ${scB.liveability > scA.liveability ? 'higher liveability scores' : scB.schools > scA.schools ? 'better school catchments' : 'closer CBD proximity'}.`;
    pills = [`<span class="rec-pill a">${dA.name} recommended</span>`,`<span class="rec-pill neutral">Score: ${totA} vs ${totB}</span>`];
  } else {
    winner = `${dB.name} edges ahead`;
    winnerSide = 'b';
    recBody = `${dB.name} scores ${totB} vs ${dA.name}'s ${totA} — a ${diff.toFixed(1)}-point lead. The key advantages are ${scB.yield > scA.yield ? 'stronger rental yield' : ''}${scB.growth > scA.growth ? (scB.yield > scA.yield ? ' and ' : '') + 'higher historical capital growth' : ''}${scB.affordability > scA.affordability ? ' and lower entry cost' : ''}. That said, ${dA.name} may suit buyers who specifically want ${scA.liveability > scB.liveability ? 'higher liveability scores' : scA.schools > scB.schools ? 'better school catchments' : 'closer CBD proximity'}.`;
    pills = [`<span class="rec-pill b">${dB.name} recommended</span>`,`<span class="rec-pill neutral">Score: ${totB} vs ${totA}</span>`];
  }
  const icons = {a:'🏆',b:'🏆',tie:'⚖️'};
  document.getElementById('recommendation').innerHTML = `
    <div class="rec-header">
      <div class="rec-icon ${winnerSide}">${icons[winnerSide]}</div>
      <div><div class="rec-title">${winner}</div><div class="rec-sub">Based on yield, growth, affordability, liveability, and infrastructure scores</div></div>
    </div>
    <div class="rec-body">${recBody}</div>
    <div class="rec-pills">${pills.join('')}</div>`;

  // ── METRICS ──
  const metrics = [
    { name:'Median Price', desc:'Selected property type', vA:fmt(medA), vB:fmt(medB), rawA:medA, rawB:medB, lowerBetter:true },
    { name:'Gross Yield', desc:'Annual rent / price', vA:fmtPct(yA), vB:fmtPct(yB), rawA:yA, rawB:yB, lowerBetter:false },
    { name:'5-Year Growth', desc:'Median price appreciation', vA:fmtPct(dA.g5), vB:fmtPct(dB.g5), rawA:dA.g5, rawB:dB.g5, lowerBetter:false },
    { name:'10-Year Growth', desc:'Long-run capital growth', vA:fmtPct(dA.g10), vB:fmtPct(dB.g10), rawA:dA.g10, rawB:dB.g10, lowerBetter:false },
    { name:'Vacancy Rate', desc:'Lower = tighter rental market', vA:fmtPct(dA.vac), vB:fmtPct(dB.vac), rawA:dA.vac, rawB:dB.vac, lowerBetter:true },
    { name:'Days on Market', desc:'Avg days to sell', vA:dA.dom+' days', vB:dB.dom+' days', rawA:dA.dom, rawB:dB.dom, lowerBetter:true },
    { name:'Distance to CBD', desc:'Approx. km by road', vA:dA.dist+'km', vB:dB.dist+'km', rawA:dA.dist, rawB:dB.dist, lowerBetter:true },
    { name:'Train Access', desc:'Score out of 10', vA:dA.train+'/10', vB:dB.train+'/10', rawA:dA.train, rawB:dB.train, lowerBetter:false },
    { name:'School Rating', desc:'Catchment quality', vA:dA.school+'/10', vB:dB.school+'/10', rawA:dA.school, rawB:dB.school, lowerBetter:false },
    { name:'Safety Score', desc:'Lower crime = higher score', vA:(10-dA.crime)+'/10', vB:(10-dB.crime)+'/10', rawA:10-dA.crime, rawB:10-dB.crime, lowerBetter:false },
    { name:'Café & Lifestyle', desc:'Walkability & amenity', vA:dA.cafe+'/10', vB:dB.cafe+'/10', rawA:dA.cafe, rawB:dB.cafe, lowerBetter:false },
    { name:'Development Activity', desc:'Pipeline & growth signal', vA:dA.dev+'/10', vB:dB.dev+'/10', rawA:dA.dev, rawB:dB.dev, lowerBetter:false },
  ];
  document.getElementById('metricsGrid').innerHTML = metrics.map(m => {
    const aWins = m.lowerBetter ? m.rawA < m.rawB : m.rawA > m.rawB;
    const bWins = m.lowerBetter ? m.rawB < m.rawA : m.rawB > m.rawA;
    const tie = m.rawA === m.rawB;
    return `<div class="metric-row">
      <div class="metric-a${aWins&&!tie?' winner':''}">
        <div class="metric-val">${m.vA}</div>
        ${aWins&&!tie?'<span class="winner-tag">Better</span>':''}
      </div>
      <div class="metric-center">
        <div class="metric-name">${m.name}</div>
        <div class="metric-desc">${m.desc}</div>
      </div>
      <div class="metric-b${bWins&&!tie?' winner':''}">
        <div class="metric-val">${m.vB}</div>
        ${bWins&&!tie?'<span class="winner-tag">Better</span>':''}
      </div>
    </div>`;
  }).join('');

  // ── SCORE CARDS ──
  const scoreLabels = {affordability:'Affordability',yield:'Rental Yield',growth:'Capital Growth',liveability:'Liveability',transport:'Transport',schools:'Schools',safety:'Safety',development:'Development'};
  function scoreCard(sc, side, name) {
    return `<div class="score-card ${side}">
      <div class="score-card-title">${name}</div>
      ${Object.entries(scoreLabels).map(([k,label])=>`
        <div class="score-bar-item">
          <div class="score-bar-header"><span class="label">${label}</span><span class="val">${parseFloat(sc[k]).toFixed(1)}/10</span></div>
          <div class="score-track"><div class="score-fill ${side}" style="width:${Math.min(100,sc[k]*10).toFixed(0)}%"></div></div>
        </div>`).join('')}
    </div>`;
  }
  document.getElementById('scoreGrid').innerHTML = scoreCard(scA,'a',dA.name) + scoreCard(scB,'b',dB.name);

  // ── 10-YEAR PROJECTION ──
  let rows = `<tr><th>Year</th><th class="a-col">${dA.name} Value</th><th class="a-col">Equity Gain</th><th class="b-col">${dB.name} Value</th><th class="b-col">Equity Gain</th></tr>`;
  let vA2 = medA, vB2 = medB;
  const grA = dA.g10 / 10 / 100, grB = dB.g10 / 10 / 100;
  for(let yr=1;yr<=10;yr++){
    vA2 *= (1+grA); vB2 *= (1+grB);
    const gainA = vA2-medA, gainB = vB2-medB;
    rows += `<tr><td>Year ${yr}</td><td class="a-col">${fmt(vA2)}</td><td class="a-col">+${fmt(gainA)}</td><td class="b-col">${fmt(vB2)}</td><td class="b-col">+${fmt(gainB)}</td></tr>`;
  }
  document.getElementById('projTable').innerHTML = rows;

  // ── BUYER PROFILES ──
  const profiles = [
    { title:'First Home Buyer', emoji:'🏠', a: medA < 800000 ? dA.name : null, b: medB < 800000 ? dB.name : null, desc: 'Needs affordability and strong liveability. Best for: low median price, good schools, safe streets.' },
    { title:'Yield Investor', emoji:'📈', a: yA >= 4.0 ? dA.name : null, b: yB >= 4.0 ? dB.name : null, desc: 'Prioritises rental income over capital growth. Best for: gross yield above 4%, low vacancy, strong rental demand.' },
    { title:'Growth Investor', emoji:'🚀', a: dA.g10 >= 70 ? dA.name : null, b: dB.g10 >= 70 ? dB.name : null, desc: 'Willing to negative gear for long-term capital gain. Best for: 10-year growth above 70%, development activity.' },
    { title:'Owner Occupier', emoji:'🌿', a: dA.live >= 8 ? dA.name : null, b: dB.live >= 8 ? dB.name : null, desc: 'Prioritises lifestyle, schools, and liveability. Best for: high liveability, transport, café score, safety.' },
    { title:'Developer / Subdivider', emoji:'🏗️', a: dA.dev >= 8 ? dA.name : null, b: dB.dev >= 8 ? dB.name : null, desc: 'Looking for development uplift and rezoning opportunity. Best for: high development activity score, growth zones.' },
  ];
  document.getElementById('profileGrid').innerHTML = profiles.map(p => {
    const fits = [];
    if(p.a) fits.push({side:'a',name:p.a});
    if(p.b) fits.push({side:'b',name:p.b});
    const badges = fits.length ? fits.map(f=>`<span class="profile-badge ${f.side}">${f.name}</span>`).join(' ') : `<span style="font-size:11px;color:var(--text3)">Neither suburb fits this profile</span>`;
    return `<div class="profile-card"><div class="profile-card-title">${p.title}</div><div class="profile-emoji">${p.emoji}</div><div style="margin-bottom:6px">${badges}</div><p>${p.desc}</p></div>`;
  }).join('');

  document.getElementById('results').classList.add('show');
  setTimeout(()=>document.getElementById('results').scrollIntoView({behavior:'smooth',block:'start'}),100);
}
